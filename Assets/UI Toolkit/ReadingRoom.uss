.screen {
    position: absolute;
    width: 100%;
    height: 100%;
    left: 0%;
    transition: left 0.4s ease;
}

.screen--hidden-left {
    left: -100%;
}

.screen--hidden-right {
    left: 100%;
}

.room-label {
    font-size: 48px;
}

.next-room-button {
    position: absolute;
    top: 50%;
    width: 100px;
    font-size: 48px;
    align-self: center;
}
